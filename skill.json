{
  "name": "umlaut",
  "version": "1.0.0",
  "description": "Web interface for monitoring and controlling OpenClaw's self-evolution engine",
  "author": "OpenClaw Team",
  "license": "MIT",
  "repository": "https://github.com/Glazkoff/umlaut",
  "keywords": [
    "openclaw",
    "evolution",
    "self-evolution",
    "autonomous-code-improvement",
    "web-ui",
    "dashboard"
  ],
  "categories": [
    "ui",
    "monitoring",
    "evolution"
  ],
  "requirements": {
    "python": ">=3.11",
    "openclaw": ">=0.1.0"
  },
  "install": {
    "command": "bash scripts/install.sh",
    "post_install": "umlaut init"
  },
  "commands": {
    "start": {
      "description": "Start Umlaut server",
      "command": "uvicorn main:app --host 127.0.0.1 --port 8080",
      "aliases": ["ui", "dashboard"]
    },
    "stop": {
      "description": "Stop Umlaut server",
      "command": "pkill -f 'uvicorn main:app --port 8080'"
    },
    "restart": {
      "description": "Restart Umlaut server",
      "command": "bash -c 'pkill -f uvicorn && sleep 2 && uvicorn main:app --host 127.0.0.1 --port 8080'"
    },
    "status": {
      "description": "Check Umlaut status",
      "command": "curl -s http://localhost:8080/api/system/status | jq ."
    },
    "logs": {
      "description": "View Umlaut logs",
      "command": "tail -f /tmp/umlaut.log"
    }
  },
  "endpoints": {
    "web": "http://localhost:8080",
    "api": "http://localhost:8080/api",
    "websocket": "ws://localhost:8080/ws"
  },
  "environment_variables": {
    "UMLAUT_HOST": {
      "description": "Host to bind server",
      "default": "127.0.0.1"
    },
    "UMLAUT_PORT": {
      "description": "Port to bind server",
      "default": "8080"
    },
    "UMLAUT_DEBUG": {
      "description": "Enable debug mode",
      "default": "false"
    },
    "LOG_LEVEL": {
      "description": "Logging level",
      "default": "INFO"
    }
  },
  "permissions": [
    "filesystem.read",
    "filesystem.write",
    "network.http",
    "network.websocket",
    "process.execute"
  ],
  "dependencies": [
    "fastapi>=0.104.0",
    "uvicorn[standard]>=0.24.0",
    "python-multipart>=0.0.6",
    "aiofiles>=23.2.1",
    "websockets>=12.0"
  ],
  "optional_dependencies": {
    "nginx": "For production deployment",
    "docker": "For containerized deployment"
  },
  "examples": [
    {
      "title": "Start Umlaut",
      "command": "umlaut start",
      "description": "Start the web interface on http://localhost:8080"
    },
    {
      "title": "Create new project",
      "command": "curl -X POST http://localhost:8080/api/projects -d '{\"name\": \"my-project\"}'",
      "description": "Create a new evolution project"
    },
    {
      "title": "Configure thinking levels",
      "command": "curl -X PUT 'http://localhost:8080/api/projects/my-project/config/thinking?phase=EXECUTE&level=medium'",
      "description": "Set EXECUTE phase to medium thinking"
    }
  ],
  "troubleshooting": [
    {
      "issue": "Port 8080 already in use",
      "solution": "Change port: uvicorn main:app --port 8081"
    },
    {
      "issue": "WebSocket connection failed",
      "solution": "Check nginx config for WebSocket support"
    },
    {
      "issue": "Evolution not starting",
      "solution": "Check project state: cat ~/.openclaw/workspace/evolution/my-project/STATE.json"
    }
  ],
  "documentation": {
    "readme": "https://github.com/Glazkoff/umlaut/blob/main/README.md",
    "api": "https://github.com/Glazkoff/umlaut/blob/main/docs/API.md",
    "examples": "https://github.com/Glazkoff/umlaut/tree/main/examples"
  },
  "support": {
    "issues": "https://github.com/Glazkoff/umlaut/issues",
    "discord": "https://discord.gg/clawd",
    "email": "support@openclaw.ai"
  },
  "changelog": "https://github.com/Glazkoff/umlaut/blob/main/CHANGELOG.md",
  "icon": "🧬",
  "screenshots": [
    "https://github.com/Glazkoff/umlaut/raw/main/docs/screenshots/dashboard.png",
    "https://github.com/Glazkoff/umlaut/raw/main/docs/screenshots/thinking-config.png"
  ]
}
