[Unit]
Description=Umlaut - OpenClaw Self-Evolution Engine Web Interface
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/.openclaw/workspace/umlaut
Environment="PATH=/root/.openclaw/workspace/umlaut/.venv/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=/root/.openclaw/workspace/umlaut/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8080
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
